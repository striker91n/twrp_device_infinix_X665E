# Android dynamic partitions
/system                 erofs       logical=system             slotselect
/system_ext             erofs       logical=system_ext         slotselect
/vendor                 erofs       logical=vendor             slotselect
/product                erofs       logical=product            slotselect

# Boot control
/boot                   emmc        /dev/block/platform/bootdevice/by-name/boot      slotselect

# VBMeta
/vbmeta                 emmc        /dev/block/platform/bootdevice/by-name/vbmeta
/vbmeta_system          emmc        /dev/block/platform/bootdevice/by-name/vbmeta_system     slotselect
/vbmeta_vendor          emmc        /dev/block/platform/bootdevice/by-name/vbmeta_vendor     slotselect

# Metadata
/metadata               ext4        /dev/block/platform/bootdevice/by-name/md_udc      wait,formattable,check

# Data
/data                   f2fs        /dev/block/platform/bootdevice/by-name/userdata     wait,quota,formattable,check,resize,latemount

# MTK special partitions
/protect_f              ext4        /dev/block/platform/bootdevice/by-name/protect1     wait,formattable,check
/protect_s              ext4        /dev/block/platform/bootdevice/by-name/protect2     wait,formattable,check
/nvdata                 ext4        /dev/block/platform/bootdevice/by-name/nvdata       wait,formattable,check
/nvcfg                  ext4        /dev/block/platform/bootdevice/by-name/nvcfg        wait,formattable,check
/persist                ext4        /dev/block/platform/bootdevice/by-name/persist      wait,formattable,check
/tranfs                 ext4        /dev/block/platform/bootdevice/by-name/tranfs       wait,formattable,check,nofail

# EMMC partitions (backup targets)
/bootloader             emmc        /dev/block/platform/bootdevice/by-name/lk
/bootloader2            emmc        /dev/block/platform/bootdevice/by-name/lk2
/misc                   emmc        /dev/block/platform/bootdevice/by-name/para
/persistent             emmc        /dev/block/platform/bootdevice/by-name/frp
/logo                   emmc        /dev/block/platform/bootdevice/by-name/logo
/expdb                  emmc        /dev/block/platform/bootdevice/by-name/expdb
/seccfg                 emmc        /dev/block/platform/bootdevice/by-name/seccfg
/tee1                   emmc        /dev/block/platform/bootdevice/by-name/tee1
/tee2                   emmc        /dev/block/platform/bootdevice/by-name/tee2
/scp1                   emmc        /dev/block/platform/bootdevice/by-name/scp1
/scp2                   emmc        /dev/block/platform/bootdevice/by-name/scp2
/sspm_1                 emmc        /dev/block/platform/bootdevice/by-name/sspm_1
/sspm_2                 emmc        /dev/block/platform/bootdevice/by-name/sspm_2
/md1img                 emmc        /dev/block/platform/bootdevice/by-name/md1img
/md1dsp                 emmc        /dev/block/platform/bootdevice/by-name/md1dsp
/md1arm7                emmc        /dev/block/platform/bootdevice/by-name/md1arm7
/md3img                 emmc        /dev/block/platform/bootdevice/by-name/md3img
/gz1                    emmc        /dev/block/platform/bootdevice/by-name/gz1
/gz2                    emmc        /dev/block/platform/bootdevice/by-name/gz2
/spmfw                  emmc        /dev/block/platform/bootdevice/by-name/spmfw
/boot_para              emmc        /dev/block/platform/bootdevice/by-name/boot_para
/odmdtbo                emmc        /dev/block/platform/bootdevice/by-name/odmdtbo
/dtbo                   emmc        /dev/block/platform/bootdevice/by-name/dtbo
/tkv                    emmc        /dev/block/platform/bootdevice/by-name/tkv
/nvram                  emmc        /dev/block/platform/bootdevice/by-name/nvram
/proinfo                emmc        /dev/block/platform/bootdevice/by-name/proinfo

# External storage
/sdcard1                vfat        /devices/platform/externdevice*         voldmanaged=sdcard1:auto
/usbotg                 vfat        /devices/platform/mt_usb*               voldmanaged=usbotg:auto
